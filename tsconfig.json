{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@api/*":       ["src/api/*"],
      "@domain/*":    ["src/domain/*"],
      "@errors/*":    ["src/errors/*"],
      "@schemas/*":   ["src/schemas/*"],
      "@fixtures/*":  ["src/fixtures/*"],
      "@app-types/*": ["src/types/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
